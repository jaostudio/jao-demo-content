# Likha Marketplace — Environment Variables
# Copy this file to .env and fill in the values.

# Database URL
# SQLite (development):  "file:./dev.db"
# PostgreSQL (production): "postgresql://user:password@host:5432/likha?schema=public"
DATABASE_URL="file:./dev.db"

# NextAuth (required for authentication)
# Generate a random string: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-string"
NEXTAUTH_URL="http://localhost:3000"

# DEMO_MODE (optional, defaults to true)
# When enabled: Stripe charges are mocked, emails are not sent,
# GCash QR code is static, and admin links are fully functional.
# Set to "false" for production with real payments.
DEMO_MODE="true"
