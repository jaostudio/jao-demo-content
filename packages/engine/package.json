{
  "name": "@jaostudio/engine",
  "version": "0.2.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaostudio/jaostudio-platform.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.mts",
      "import": "./dist/types/index.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.mts",
      "import": "./dist/types/*.js"
    },
    "./rendering": {
      "types": "./dist/rendering/index.d.mts",
      "import": "./dist/rendering/index.js"
    },
    "./rendering/*": {
      "types": "./dist/rendering/*.d.mts",
      "import": "./dist/rendering/*.js"
    },
    "./transitions": {
      "types": "./dist/transitions/index.d.mts",
      "import": "./dist/transitions/index.js"
    },
    "./transitions/*": {
      "types": "./dist/transitions/*.d.mts",
      "import": "./dist/transitions/*.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.mts",
      "import": "./dist/theme/index.js"
    },
    "./composition": {
      "types": "./dist/composition/index.d.mts",
      "import": "./dist/composition/index.js"
    },
    "./composition/*": {
      "types": "./dist/composition/*.d.mts",
      "import": "./dist/composition/*.js"
    }
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "framer-motion": "^12.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  }
}
