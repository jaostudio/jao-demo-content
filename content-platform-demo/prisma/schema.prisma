generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/content-client"
}

datasource db {
  provider = "sqlite"
}

enum AuthorRole {
  AUTHOR
  ADMIN
}

enum ArticleStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
}

model Author {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  role      AuthorRole @default(AUTHOR)
  image     String?
  createdAt DateTime   @default(now())

  articles    Article[]
  moderated   Article[] @relation("ModeratedArticles")
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  articles Article[]
}

model Tag {
  id       String       @id @default(cuid())
  name     String
  slug     String       @unique
  articles ArticleTag[]
}

model Article {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String?
  content        String
  status         ArticleStatus @default(DRAFT)
  metaTitle      String?
  metaDescription String?
  canonicalUrl   String?
  publishAt      DateTime?
  moderatedAt    DateTime?
  moderatedById  String?
  moderatedBy    Author?       @relation("ModeratedArticles", fields: [moderatedById], references: [id])
  authorId       String
  author         Author        @relation(fields: [authorId], references: [id])
  categoryId     String
  category       Category      @relation(fields: [categoryId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tags     ArticleTag[]
  versions ArticleVersion[]
}

model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model ArticleVersion {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}
