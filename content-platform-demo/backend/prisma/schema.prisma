generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client"
}

datasource db {
  provider = "sqlite"
}

enum AuthorRole {
  AUTHOR
  ADMIN
}

enum MediaFormat {
  DRAWING
  WRITING
  VIDEO
  AUDIO
}

enum ArticleStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
}

enum ProvenanceStatus {
  UNDECLARED
  DECLARED_HUMAN_MADE
  AI_ASSISTED
  PROCESS_DOCUMENTED
  REMOVED_BY_ADMIN
}

model Author {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  role      AuthorRole @default(AUTHOR)
  image     String?
  bio       String?
  specialty String?
  createdAt DateTime   @default(now())

  articles    Article[]
  moderated   Article[] @relation("ModeratedArticles")
  followers   Follow[]      @relation("UserFollowers")
  following   Follow[]      @relation("UserFollowing")
  collections Collection[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  articles Article[]
}

model Tag {
  id       String       @id @default(cuid())
  name     String
  slug     String       @unique
  articles ArticleTag[]
}

model Article {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  format         MediaFormat   @default(WRITING)
  imageUrl       String?
  excerpt        String?
  content        String
  aiFreeDeclaration Boolean        @default(false)
  provenanceStatus  ProvenanceStatus @default(UNDECLARED)
  provenanceNote    String?
  likes             Int           @default(0)
  status         ArticleStatus @default(DRAFT)
  metaTitle      String?
  metaDescription String?
  canonicalUrl   String?
  publishAt      DateTime?
  moderatedAt    DateTime?
  moderatedById  String?
  moderatedBy    Author?       @relation("ModeratedArticles", fields: [moderatedById], references: [id])
  authorId       String
  author         Author        @relation(fields: [authorId], references: [id])
  categoryId     String
  category       Category      @relation(fields: [categoryId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tags     ArticleTag[]
  versions ArticleVersion[]
  comments Comment[]
  collectionItems CollectionItem[]

  @@index([status])
  @@index([authorId])
  @@index([publishAt])
}

model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model ArticleVersion {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content   String
  version   Int      @default(1)
  changeNote String?
  mediaUrl   String?
  createdAt DateTime @default(now())

  @@unique([articleId, version])
}

enum CollectionVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

model Collection {
  id          String               @id @default(cuid())
  ownerId     String
  slug        String
  title       String
  description String?
  cover       String?
  visibility  CollectionVisibility @default(PUBLIC)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  owner Author           @relation(fields: [ownerId], references: [id])
  items CollectionItem[]

  @@unique([ownerId, slug])
  @@index([ownerId])
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  articleId    String
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  article    Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([collectionId, articleId])
  @@index([articleId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  Author @relation("UserFollowing", fields: [followerId], references: [id])
  following Author @relation("UserFollowers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Comment {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorName  String
  authorEmail String
  body        String
  createdAt   DateTime @default(now())

  @@index([articleId])
}
