    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "lucide-react": "^0.500.0",
    "next": "^16.1.0",
    "next-auth": "^4.24.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
