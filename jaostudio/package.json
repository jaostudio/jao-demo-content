{
  "name": "jaostudio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:browser": "cross-env ANALYZE=true ANALYZE_TARGET=browser next build",
    "analyze:server": "cross-env ANALYZE=true ANALYZE_TARGET=server next build",
    "qa:smoke": "node ./scripts/smoke.js",
    "qa:lighthouse": "node ./scripts/lighthouse.js",
    "qa:screenshots": "node ./scripts/screenshots.js",
    "qa:all": "npm run qa:smoke -- && npm run qa:lighthouse -- && npm run qa:screenshots --",
    "i18n:report": "node ./scripts/translations-report.js",
    "i18n:check": "node ./scripts/translations-report.js --fail-under=65 && node ./scripts/validate-contracts.js && node ./scripts/funnel-qa.js && node ./scripts/cta-consistency.js && node ./scripts/orphan-detection.js",
    "i18n:leakage": "node ./scripts/translations-report.js --detect-english-leakage",
    "i18n:drift": "node ./scripts/translations-report.js --detect-drift",
    "i18n:meta": "node ./scripts/translations-report.js --detect-meta-length",
    "i18n:unused": "node ./scripts/unused-keys.js",
    "i18n:funnel": "node ./scripts/funnel-qa.js",
    "i18n:cta": "node ./scripts/cta-consistency.js",
    "i18n:orphans": "node ./scripts/orphan-detection.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.55.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "next": "15.5.18",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.379.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.12.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chrome-launcher": "^1.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "fs-extra": "^11.1.1",
    "lighthouse": "^13.3.0",
    "playwright": "^1.40.0",
    "sharp": "^0.33.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "yargs": "^17.7.2"
  }
}
